datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String          @unique
  passwordHash   String          @map("password_hash")
  createdAt      DateTime?       @default(now()) @map("created_at") @db.Timestamptz
  apiCredentials ApiCredential[]
  agentConfigs   AgentConfig[]

  @@map("users")
}

model ApiCredential {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  provider     String    // 'deepgram' | 'openai'
  encryptedKey String    @map("encrypted_key")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("api_credentials")
}

model AgentConfig {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                    String    @map("user_id") @db.Uuid
  name                      String?
  systemPrompt              String    @map("system_prompt")
  llmModel                  String    @map("llm_model") // 'gpt-4o' | 'gpt-4o-mini'
  voicePreference           String?   @map("voice_preference")
  jobDescription            String?   @map("job_description")
  candidateResume           String?   @map("candidate_resume")
  interviewPreferences      Json?     @map("interview_preferences")
  interviewDurationMinutes  Int?      @map("interview_duration_minutes")
  uploadedQuestions         Json?     @map("uploaded_questions")
  createdAt                 DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  user                      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions                  Session[]

  @@map("agent_configs")
}

model Session {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentConfigId String         @map("agent_config_id") @db.Uuid
  status        String         @default("active") // 'active' | 'completed' | 'aborted'
  startedAt     DateTime?      @default(now()) @map("started_at") @db.Timestamptz
  endedAt       DateTime?      @map("ended_at") @db.Timestamptz
  summary       String?
  agentConfig   AgentConfig    @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)
  messages      Message[]
  sessionEvents SessionEvent[]

  @@map("sessions")
}

model Message {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String    @map("session_id") @db.Uuid
  role      String    // 'user' | 'assistant' | 'system_event'
  content   String
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz
  session   Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model SessionEvent {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String    @map("session_id") @db.Uuid
  eventType String    @map("event_type") // 'silence_prompt' | 'interruption' | 'utterance_end'
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz
  metadata  Json?
  session   Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_events")
}
